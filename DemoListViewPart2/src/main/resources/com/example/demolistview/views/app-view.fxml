<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="400.0" prefWidth="600.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.example.demolistview.controllers.AppControllers">
   <children>
      <Label text="Lista de Personas" />
      <GridPane prefHeight="60.0" prefWidth="600.0">
        <columnConstraints>
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
          <ColumnConstraints hgrow="SOMETIMES" minWidth="10.0" prefWidth="100.0" />
        </columnConstraints>
        <rowConstraints>
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
          <RowConstraints minHeight="10.0" prefHeight="30.0" vgrow="SOMETIMES" />
        </rowConstraints>
         <children>
            <Label text="Name" />
            <Label text="Email" GridPane.rowIndex="1" />
            <TextField fx:id="txtName" promptText="Name" GridPane.columnIndex="1" />
            <TextField fx:id="txtEmail" promptText="Email" GridPane.columnIndex="1" GridPane.rowIndex="1" />
            <TextField fx:id="txtAge" promptText="Age" GridPane.columnIndex="1" GridPane.rowIndex="2" />
            <Label text="Age" GridPane.rowIndex="2" />
         </children>
      </GridPane>
      <HBox prefHeight="100.0" prefWidth="200.0">
         <children>
            <Button mnemonicParsing="false" onAction="#onReload" text="Recargar" />
            <Button mnemonicParsing="false" onAction="#onAdd" text="Agregar" />
            <Button mnemonicParsing="false" onAction="#onUpdate" text="Actualizar" />
            <Button mnemonicParsing="false" onAction="#onDelete" text="Eliminar" />
         </children>
      </HBox>
      <ListView fx:id="listView" prefHeight="200.0" prefWidth="200.0" />
      <Label fx:id="lblMsg" />
   </children>
</VBox>
